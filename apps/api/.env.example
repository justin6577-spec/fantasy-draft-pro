# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fantasy_draft?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-at-least-24-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-24-characters
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Sign in with Apple / Google
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# AI provider (server-side only, never shipped to the client)
OPENAI_API_KEY=

# Yahoo Fantasy Sports OAuth
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=
# Required for Yahoo token storage. Generate with: openssl rand -base64 32
YAHOO_CREDENTIAL_ENCRYPTION_KEY=

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=

# News provider (pluggable - see src/modules/news/providers)
NEWS_PROVIDER=mock
NEWS_PROVIDER_API_KEY=
